# Frontend Environment Variables
# Copy this file to .env and fill in your actual values

# API URL - Backend server URL
VITE_API_URL=http://localhost:5000/api

# Socket.io URL (for real-time features)
VITE_SOCKET_URL=http://localhost:5000

# Optional: Google OAuth Client ID (if using Google Sign-In)
# VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# ============================================
# Docker Environment Variables (optional)
# These are only used when running with Docker
# ============================================

# JWT Secret for backend (generate a strong random string)
# JWT_SECRET=your_jwt_secret_key_change_this_in_production

# Grafana Admin Password
# GRAFANA_PASSWORD=admin
