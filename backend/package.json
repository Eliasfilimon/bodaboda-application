{
  "name": "boda-boda-backend",
  "version": "1.0.0",
  "description": "Backend API for Boda Boda Digital ride-hailing app",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "db:setup": "node scripts/createDb.js",
    "db:seed": "node scripts/seedData.js",
    "test": "node --input-type=module -e \"import('./src/app.js').then(() => process.exit(0)).catch((err) => { console.error(err); process.exit(1); })\""
  },
  "keywords": [
    "boda-boda",
    "ride-hailing",
    "express",
    "postgresql",
    "socket.io"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.0",
    "google-auth-library": "^9.4.0",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "prom-client": "^15.1.3",
    "sequelize": "^6.37.8",
    "socket.io": "^4.6.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
