# ─── Server ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── PostgreSQL via AWS RDS ───────────────────────────────────────────────────
# Full connection URL (recommended — used in production on ECS)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_RDS_ENDPOINT:5432/bodaboda

# Individual vars (used for local dev without Docker)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bodaboda
DB_USER=postgres
DB_PASSWORD=postgres

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# ─── MQTT Broker ─────────────────────────────────────────────────────────────
# Local dev
MQTT_BROKER_URL=mqtt://localhost:1883
# AWS (if using your own MQTT on EC2 or ECS)
# MQTT_BROKER_URL=mqtt://YOUR_EC2_OR_ECS_IP:1883

# ─── CORS ────────────────────────────────────────────────────────────────────
# Local dev
CORS_ORIGIN=http://localhost:5173
# Production (your CloudFront domain)
# CORS_ORIGIN=https://YOUR_CLOUDFRONT_DOMAIN.cloudfront.net

# ─── AWS (needed for GitHub Actions / ECS deploy) ────────────────────────────
# These go into GitHub Secrets — NOT in this file in production
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# ECR_REGISTRY=123456789.dkr.ecr.us-east-1.amazonaws.com
# ECR_REPOSITORY_BACKEND=bodaboda-backend
# ECR_REPOSITORY_FRONTEND=bodaboda-frontend
# ECS_CLUSTER=bodaboda-cluster
# ECS_SERVICE_BACKEND=bodaboda-backend-service
# ECS_SERVICE_FRONTEND=bodaboda-frontend-service
# S3_BUCKET=bodaboda-frontend
# CLOUDFRONT_DISTRIBUTION_ID=EXXXXXXXXX
